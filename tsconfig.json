{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "moduleResolution": "bundler",
    // Hace que TS siga la condiciĂłn `react-native` de los exports maps.
    // Necesario para que Firebase v12 expose `getReactNativePersistence`
    // desde `firebase/auth` (vive solo en el build de RN, no en el default).
    "customConditions": ["react-native"],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "types/**/*.d.ts"
  ]
}
