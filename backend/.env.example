# Copiar este archivo a .env y completar los valores reales.
# El .env NO se commitea (está en .gitignore).

# ─── Base de datos ────────────────────────────────────────────────
# En dev (docker-compose) apuntamos al servicio `postgres` del compose.
# En producción (Fly.io) se inyecta el DATABASE_URL de Neon via secret.
DATABASE_URL=postgresql+asyncpg://rutas:dev_password@postgres:5432/rutas

# ─── Firebase ─────────────────────────────────────────────────────
# Ruta al archivo JSON de service-account descargado de
# console.firebase.google.com → Project Settings → Service Accounts.
# Para producción, el contenido se inyecta via `fly secrets set`.
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# ─── Runtime ──────────────────────────────────────────────────────
APP_ENV=development             # development | staging | production
LOG_LEVEL=debug                 # debug | info | warning | error

# ─── CORS ─────────────────────────────────────────────────────────
# Orígenes permitidos, separados por coma. En dev "*" está bien;
# en prod listar solo dominios del dashboard admin.
CORS_ORIGINS=*
