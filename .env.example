# .env.example — copia este archivo como `.env` y completa los valores.
# El `.env` real está ignorado por git; este solo documenta las variables.

# ─── API KEYS (producción) ────────────────────────────────────────────────
# Key de Google Maps — usada por StreetViewModal para el embed de Street View.
# Debe estar restringida en Google Cloud Console por package name + SHA-1.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Key de OpenRouteService — usada por poiService para cargar hospitales/CAI
# cerca del usuario. Opcional: si no se define, los POIs externos se desactivan.
EXPO_PUBLIC_ORS_API_KEY=

# ─── DESARROLLO ────────────────────────────────────────────────────────────
# Mock de ubicación: cuando está en "1", la app usa una posición fija dentro
# del grafo de Santa Rosa en vez del GPS real. Útil para probar flujos
# completos desde fuera de la zona. Ver src/utils/devMock.ts.
#
# IMPORTANTE: apagar (comentar o poner "0") antes de cada build de
# producción — aparece un badge "📍 DEV MOCK" en el mapa como recordatorio.
# EXPO_PUBLIC_DEV_MOCK_LOCATION=1
